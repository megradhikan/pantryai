# ── FRONTEND (.env.local) ──────────────────────────────────────
# Supabase: dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here        # "anon public" key
# FastAPI base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
# Admin eval page: only this email can access /admin/eval
NEXT_PUBLIC_ADMIN_EMAIL=your@email.com
# Web Push — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── BACKEND (.env) ─────────────────────────────────────────────
# Supabase: dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here    # "service_role" key (reveal)
SUPABASE_JWT_SECRET=your-jwt-secret-here                # Settings → API → JWT Settings → JWT Secret (reveal)

# Google Gemini — free at aistudio.google.com → Get API key
GEMINI_API_KEY=AIza...

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=your@email.com
